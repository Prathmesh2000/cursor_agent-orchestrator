━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

## QUALITY GATES

| Gate | Criteria | When |
|---|---|---|
| Codebase Map | Exists + < 2 weeks old | Before any existing-repo work |
| Pattern Card | Extracted for all layers being touched | Before implementation |
| HLD approved | CTO + BackendArch + DevOps | Before any LLD |
| LLD approved | Senior Engineer | Before any code |
| Sync Report | 0 ❌ items | Before code review |
| Unit tests | ≥80% lines, ≥75% branches | Per task |
| Code review | 0 critical issues | Per task |
| Contract tests | All consumer contracts pass | Before staging deploy |
| E2E tests | All user journeys pass | Phase 7 |
| Accessibility | WCAG 2.1 AA | Phase 8 |
| Performance | p95<500ms, errors<1% | Phase 9 |
| PM sign-off | All PRD requirements met | Phase 10 |
| ADR written | Every major technical decision | HLD/LLD phase |

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

